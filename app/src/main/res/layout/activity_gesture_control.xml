<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Điều khiển cử chỉ"
            app:titleTextColor="@color/primary"
            app:navigationIcon="@drawable/ic_gesture"
            app:navigationIconTint="@color/primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Gesture Status -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_variant"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">
                    <TextView
                        android:id="@+id/tvGestureEmoji"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🤚"
                        android:textSize="64sp" />
                    <TextView
                        android:id="@+id/tvGestureName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đang chờ cử chỉ..."
                        style="@style/GestureLabel"
                        android:layout_marginTop="8dp" />
                    <TextView
                        android:id="@+id/tvGestureAction"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hãy di chuyển điện thoại để bắt đầu"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Toggle Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleGesture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Bắt đầu nhận diện"
                app:cornerRadius="12dp" />

            <!-- Sensor Data -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DỮ LIỆU CẢM BIẾN"
                style="@style/SectionTitle"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <!-- Accelerometer -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accelerometer (m/s²)"
                        android:textColor="@color/gesture_tilt"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView android:id="@+id/tvAccelX" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="X: 0.00" android:textColor="@color/status_off" android:textSize="14sp" />
                        <TextView android:id="@+id/tvAccelY" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Y: 0.00" android:textColor="@color/status_on" android:textSize="14sp" />
                        <TextView android:id="@+id/tvAccelZ" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Z: 0.00" android:textColor="@color/status_info" android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Gyroscope -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Gyroscope (rad/s)"
                        android:textColor="@color/gesture_rotate"
                        android:textSize="13sp"
                        android:textStyle="bold" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView android:id="@+id/tvGyroX" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="X: 0.00" android:textColor="@color/status_off" android:textSize="14sp" />
                        <TextView android:id="@+id/tvGyroY" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Y: 0.00" android:textColor="@color/status_on" android:textSize="14sp" />
                        <TextView android:id="@+id/tvGyroZ" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Z: 0.00" android:textColor="@color/status_info" android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Gesture Guide -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HƯỚNG DẪN CỬ CHỈ"
                style="@style/SectionTitle"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="👋 Vẫy tay qua trước điện thoại → Bật/Tắt đèn" android:textColor="@color/on_surface" android:textSize="14sp" android:padding="4dp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📱 Nghiêng lên/xuống → Tăng/Giảm âm lượng" android:textColor="@color/on_surface" android:textSize="14sp" android:padding="4dp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🔄 Xoay trái/phải → Chuyển bài hát" android:textColor="@color/on_surface" android:textSize="14sp" android:padding="4dp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🔃 Lật điện thoại → Bật/Tắt quạt" android:textColor="@color/on_surface" android:textSize="14sp" android:padding="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Command Log -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NHẬT KÝ LỆNH"
                style="@style/SectionTitle"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvCommandLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chưa có lệnh nào được gửi"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />
                </ScrollView>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
