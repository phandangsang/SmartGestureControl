<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Cài đặt"
            app:titleTextColor="@color/primary"
            app:navigationIcon="@drawable/ic_settings"
            app:navigationIconTint="@color/primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Sensitivity Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ĐỘ NHẠY CỬ CHỈ"
                style="@style/SectionTitle"
                android:layout_marginBottom="12dp" />



            <!-- Tilt Threshold -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="📱 Ngưỡng nghiêng" android:textColor="@color/on_surface" android:textSize="14sp" />
                        <TextView android:id="@+id/tvTiltValue" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="5.0" android:textColor="@color/primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderTilt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="2"
                        android:valueTo="10"
                        android:value="5"
                        android:stepSize="0.5" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Rotate Threshold -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="🔄 Ngưỡng xoay" android:textColor="@color/on_surface" android:textSize="14sp" />
                        <TextView android:id="@+id/tvRotateValue" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="3.0" android:textColor="@color/primary" android:textSize="14sp" android:textStyle="bold" />
                    </LinearLayout>
                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderRotate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0.5"
                        android:valueTo="6"
                        android:value="2.5"
                        android:stepSize="0.5" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Options Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TÙY CHỌN"
                style="@style/SectionTitle"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="12dp" />

            <!-- Vibration -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Rung phản hồi khi phát hiện cử chỉ" android:textColor="@color/on_surface" android:textSize="14sp" />
                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchVibration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reset & About -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReset"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Khôi phục mặc định"
                app:cornerRadius="12dp"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <!-- About -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Smart Gesture Control" android:textColor="@color/primary" android:textSize="16sp" android:textStyle="bold" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Phiên bản 1.0" android:textColor="@color/on_surface_variant" android:textSize="13sp" android:layout_marginTop="4dp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Điều khiển thiết bị IoT bằng cử chỉ" android:textColor="@color/on_surface_variant" android:textSize="13sp" android:layout_marginTop="2dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
