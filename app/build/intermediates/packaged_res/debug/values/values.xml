    <style name="CardStyle" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <style name="DeviceCardStyle" parent="CardStyle">
        <item name="contentPadding">@dimen/card_padding</item>
    </style>
    <style name="GestureLabel">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="SectionTitle">
        <item name="android:textSize">@dimen/text_subtitle</item>
        <item name="android:textColor">@color/on_surface_variant</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="Theme.SmartGestureControl" parent="Theme.Material3.Dark.NoActionBar">
