<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Điều khiển cử chỉ"
            app:titleTextColor="@color/primary"
            app:navigationIcon="@drawable/ic_gesture"
            app:navigationIconTint="@color/primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Toggle Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnToggleGesture"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="Bắt đầu nhận diện"
                app:cornerRadius="12dp" />

            <!-- Dashboard Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="16dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <!-- REAL-TIME GESTURE -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:id="@+id/tvDashboardEmoji"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✋"
                            android:textSize="20sp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:id="@+id/tvDashboardStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cử chỉ: Đang chờ..."
                            android:textColor="@color/on_surface"
                            android:textSize="16sp"
                            android:fontFamily="monospace"/>
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvDashboardRecognized"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✅ Nhận diện: CHƯA CÓ"
                        android:textColor="@color/status_on"
                        android:textSize="14sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="4dp"
                        android:layout_marginStart="32dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:layout_marginVertical="12dp" />

                    <!-- DEVICE STATUS: LIGHT -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="💡 ĐÈN" android:textColor="@color/on_surface" android:fontFamily="monospace" android:textSize="14sp" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/tvLightState"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="[ TẮT ● ]"
                            android:background="@drawable/bg_label_off"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:textColor="@color/on_surface_variant"
                            android:fontFamily="monospace"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- DEVICE STATUS: VOLUME -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🔊 ÂM LƯỢNG" android:textColor="@color/on_surface" android:fontFamily="monospace" android:textSize="14sp" android:layout_marginEnd="12dp"/>
                        <ProgressBar
                            android:id="@+id/pbVolume"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="8dp"
                            android:layout_weight="1"
                            android:max="100"
                            android:progress="50"
                            android:progressDrawable="@drawable/custom_progress_bar"/>
                        <TextView
                            android:id="@+id/tvVolumeVal"
                            android:layout_width="50dp"
                            android:layout_height="wrap_content"
                            android:text="50%"
                            android:gravity="end"
                            android:textColor="@color/on_surface"
                            android:fontFamily="monospace"
                            android:textSize="14sp"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <!-- DEVICE STATUS: MEDIA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="🎵 ĐANG PHÁT" android:textColor="@color/on_surface" android:fontFamily="monospace" android:textSize="14sp" android:layout_weight="1"/>
                        <TextView
                            android:id="@+id/tvSongName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bài 1 ►"
                            android:textColor="@color/on_surface"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:textSize="14sp"/>
                    </LinearLayout>



                    <!-- LIVE SENSORS -->
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📊 Cảm biến (live)" android:textColor="@color/on_surface_variant" android:fontFamily="monospace" android:textSize="14sp" android:layout_marginBottom="12dp"/>
                    
                    <!-- aX -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="aX:" android:textColor="@color/on_surface" android:fontFamily="monospace" android:textSize="12sp"/>
                        <ProgressBar android:id="@+id/pbAx" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:max="300" android:progress="150" android:progressDrawable="@drawable/custom_progress_bar"/>
                        <TextView android:id="@+id/tvAxVal" android:layout_width="80dp" android:layout_height="wrap_content" android:text="0.0 m/s²" android:gravity="end" android:textColor="@color/on_surface" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginStart="8dp"/>
                    </LinearLayout>
                    <!-- aY -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="aY:" android:textColor="@color/on_surface" android:fontFamily="monospace" android:textSize="12sp"/>
                        <ProgressBar android:id="@+id/pbAy" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:max="300" android:progress="150" android:progressDrawable="@drawable/custom_progress_bar"/>
                        <TextView android:id="@+id/tvAyVal" android:layout_width="80dp" android:layout_height="wrap_content" android:text="0.0 m/s²" android:gravity="end" android:textColor="@color/on_surface" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginStart="8dp"/>
                    </LinearLayout>
                    <!-- gZ -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical">
                        <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="gZ:" android:textColor="@color/on_surface" android:fontFamily="monospace" android:textSize="12sp"/>
                        <ProgressBar android:id="@+id/pbGz" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_height="6dp" android:layout_weight="1" android:max="200" android:progress="100" android:progressDrawable="@drawable/custom_progress_bar"/>
                        <TextView android:id="@+id/tvGzVal" android:layout_width="80dp" android:layout_height="wrap_content" android:text="0.0 rad/s" android:gravity="end" android:textColor="@color/on_surface" android:fontFamily="monospace" android:textSize="12sp" android:layout_marginStart="8dp"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Gesture Guide (Keep simplified) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HƯỚNG DẪN CỬ CHỈ"
                style="@style/SectionTitle"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="12dp">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="👋 Vẫy tay trước màn hình → Bật/Tắt đèn" android:textColor="@color/on_surface" android:textSize="14sp" android:padding="4dp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="📱 Nghiêng lên/xuống → Tăng/Giảm âm lượng" android:textColor="@color/on_surface" android:textSize="14sp" android:padding="4dp" />
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="🔄 Xoay điện thoại trái/phải → Chuyển bài" android:textColor="@color/on_surface" android:textSize="14sp" android:padding="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Command Log -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NHẬT KÝ LỆNH"
                style="@style/SectionTitle"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/card_bg"
                app:cardCornerRadius="12dp"
                app:strokeColor="@color/card_stroke"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">
                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:padding="12dp">
                    <TextView
                        android:id="@+id/tvCommandLog"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Chưa có lệnh nào được gửi"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />
                </ScrollView>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
